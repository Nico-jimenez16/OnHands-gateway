# =====================================================================
# Configuracion del API Gateway (FastAPI)
# Copia este archivo a `api_gateway/.env` y completa los valores.
# `.env` esta en .gitignore: NUNCA commitees credenciales reales.
#
# NOTA: core/settings.py exige TODAS estas variables; si falta alguna,
# la app falla al arrancar. En Docker, los hosts son nombres de
# contenedor (ej. http://ticket-service:8003), no localhost.
# =====================================================================

# --- Aplicacion ---
app_name="OnHands API Gateway"
app_description="API Gateway del monorepo OnHands"
app_version="1.0.0"
app_env="development"
app_host="127.0.0.1"
app_port=8000

# --- URLs de microservicios downstream ---
# Local (cada servicio en su puerto) / Docker (nombre de contenedor):
AUTH_SERVICE_URL="http://localhost:8001"
USERS_SERVICE_URL="http://localhost:8002"
REQUEST_SERVICE_URL="http://localhost:8003"
CORE_SERVICE_URL="http://localhost:8010"

# --- Seguridad / JWT ---
# Genera un secreto fuerte y unico, p.ej.: openssl rand -hex 32
JWT_SECRET_KEY="cambia-esto-por-un-secreto-fuerte-y-unico"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=60
